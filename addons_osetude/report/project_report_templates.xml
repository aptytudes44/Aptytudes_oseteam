<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_project_document">
        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
        <div class="page">
            <div class="oe_structure"/>

            <div class="col-3">
                <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" style="max-height: 55px;" alt="Logo"/>
            </div>
            <h2>
                Project : <span t-field="doc.name"/>
            </h2>
            <div class="col-12 mb1" style="border: 0px solid gray; min-height: 140px;">
                <table border="0" cellspacing="3px" width="100%">
                    <tr style="height: 40px;">
                        <td colspan="4"><b>Business reference : </b><span t-field="doc.title_project"/><br/><br/></td>
                    </tr>
                    <tr>
                        <td style="font-size: 15px;" width="25%"><b>Create date :</b></td><td style="font-size: 15px;" width="25%"><span t-field="doc.create_date"/></td>
                        <td style="font-size: 15px;"><b>Customer reference :</b></td><td style="font-size: 15px;"><span t-field="doc.customer_reference"/></td>
                    </tr>
                    <tr>
                        <td style="font-size: 15px; vertical-align: top;"><b>Response date :</b></td><td style="font-size: 15px; vertical-align: top;"><span t-field="doc.response_date"/></td>
                        <td style="font-size: 15px; vertical-align: top;"><b>Customer :</b></td><td style="font-size: 15px; vertical-align: top;"><span t-field="doc.partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": true, "phone_icons": true}'/></td>
                    </tr>
                    <tr>
                        <td style="font-size: 15px; vertical-align: top;"><b>Responsible :</b></td><td style="font-size: 15px; vertical-align: top;"><span t-field="doc.user_id"/></td>
                        <td style="font-size: 15px;"><b>Buyer :</b></td><td style="font-size: 15px;"><span t-field="doc.buyer_id"/></td>
                    </tr>
                    <tr>
                        <td style="font-size: 15px; vertical-align: top;"><b>Tools number :</b></td><td style="font-size: 15px; vertical-align: top;"><span t-field="doc.tools_number"/></td>
                        <td style="font-size: 15px;"><b>Phone :</b></td><td style="font-size: 15px;"><span t-field="doc.phone_buyer"/></td>
                    </tr>
                    <tr>
                        <td></td><td></td>
                        <td style="font-size: 15px;"><b>Mail :</b></td><td style="font-size: 15px;"><span t-field="doc.mail_buyer"/></td>
                    </tr>
                    <tr>
                        <td></td><td></td>
                        <td style="font-size: 15px;"><b>Responsible business :</b></td><td style="font-size: 15px;"><span t-field="doc.responsible_business_id"/></td>
                    </tr>
                    <tr>
                        <td></td><td></td>
                        <td style="font-size: 15px;"><b>Phone :</b></td><td style="font-size: 15px;"><span t-field="doc.phone_responsible_business"/></td>
                    </tr>
                    <tr>
                        <td></td><td></td>
                        <td style="font-size: 15px;"><b>Email :</b></td><td style="font-size: 15px;"><span t-field="doc.mail_responsible_business"/></td>
                    </tr>
                    <tr>
                        <td colspan="4" style="font-size: 15px;"><b>Note for the project : </b></td>
                    </tr>
                    <tr>
                        <td colspan="4" style="font-size: 15px; height: 150px; border: 1px solid gray; vertical-align: top;"><span t-field="doc.note"/></td>
                    </tr>
                </table>
            </div>
            <div class="oe_structure"/>
        </div>
    </template>

    <template id="report_project">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="addons_osetude.report_project_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>

