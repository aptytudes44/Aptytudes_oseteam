<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchaseorder_document_inherit" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//h2" position="before">
            <br/>
        </xpath>

        <!-- v17 : target only thead (replacing full table loses tbody) -->
        <xpath expr="//table[contains(@class,'o_main_table')]/thead" position="replace">
            <thead>
                <tr>
                    <th name="th_description"><span>Description</span></th>
                    <th class="text-end" name="th_qty"><span>Qty</span></th>
                    <th class="text-end" name="th_unit"><span>Unit</span></th>
                    <th class="text-end" name="th_priceunit"><span>Unit Price</span></th>
                    <th class="text-end" name="th_taxes"><span>Taxes</span></th>
                    <th class="text-end" name="th_subtotal"><span>Subtotal</span></th>
                </tr>
            </thead>
        </xpath>
    </template>
</odoo>

