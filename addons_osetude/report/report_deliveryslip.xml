<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_delivery_document_inherit_sale_stock_inherit" inherit_id="stock.report_delivery_document">
        <!-- Remplacer thead table des mouvements (non done) -->
        <xpath expr="//table[@name='stock_move_table']/thead" position="replace">
            <thead>
                <tr>
                    <th><strong>Product</strong></th>
                    <th><strong>Description</strong></th>
                    <th class="text-center"><strong>Scheduled Date</strong></th>
                    <th class="text-center"><strong>Demand</strong></th>
                    <th class="text-center"><strong>Done</strong></th>
                </tr>
            </thead>
        </xpath>

        <!-- Remplacer thead table des move lines (done) -->
        <xpath expr="//table[@name='stock_move_line_table']/thead" position="replace">
            <thead>
                <tr>
                    <th><strong>Product</strong></th>
                    <th><strong>Description</strong></th>
                    <th class="text-center"><strong>Lot/Serial</strong></th>
                    <th class="text-center"><strong>Demand</strong></th>
                    <th class="text-center"><strong>Delivered</strong></th>
                </tr>
            </thead>
        </xpath>
    </template>
</odoo>

