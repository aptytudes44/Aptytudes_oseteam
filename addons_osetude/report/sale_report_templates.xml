<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit_sale_management_inherit" inherit_id="sale_management.report_saleorder_document_inherit_sale_management">
        <xpath expr="//table[@name='table_optional_products']" position="replace">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th class="text-left">Description</th>
                        <th t-if="has_option_discount" groups="sale.group_discount_per_so_line" class="text-left"></th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Unit Price HT</th>
                        <th class="text-end">Total HT</th>
                    </tr>
                </thead>
                <tbody class="sale_tbody">
                    <tr t-foreach="doc.sale_order_option_ids" t-as="option">
                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if option.display_type == 'line_section' else 'font-italic o_line_note' if option.display_type == 'line_note' else ''">
                            <t t-if="not option.display_type">
                                <td>
                                    <span t-field="option.name"/>
                                </td>
                                <td t-if="has_option_discount" groups="sale.group_discount_per_so_line">
                                    <strong t-if="option.discount != 0.0" class="text-info">
                                        <t t-esc="((option.discount % 1) and '%s' or '%d') % option.discount"/>% discount
                                    </strong>
                                </td>
                                <td class="text-end">
                                    <span t-field="option.quantity"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="option.price_unit" t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                </td>
                                <td class="text-end">
                                    <strong>
                                        <span t-esc="'%.2f' % (option.price_unit*option.quantity)"
                                              t-att-style="option.discount and 'text-decoration: line-through' or None"
                                              t-att-class="option.discount and 'text-danger' or None"/>
                                        <span t-field="doc.pricelist_id.currency_id.symbol"/>
                                        <div t-if="option.discount">
                                            <span t-esc="'%.2f' % ((1-option.discount / 100.0) * (option.price_unit*option.quantity))"/>
                                            <span t-field="doc.pricelist_id.currency_id.symbol"/>
                                        </div>
                                    </strong>
                                </td>
                            </t>
                            <t t-if="option.display_type == 'line_section'">
                                <td colspan="99">
                                    <span t-field="option.name"/>
                                </td>
                            </t>
                            <t t-if="option.display_type == 'line_note'">
                                <td colspan="99">
                                    <span t-field="option.name"/>
                                </td>
                            </t>
                        </tr>
                    </tr>
                </tbody>
            </table>
        </xpath>
    </template>

    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document">
        <!-- GESTION DES ADRESSES -->
        <xpath expr="//t[@t-set='address']" position="replace">
            <table style="width: 100%;">
                <thead>
                    <th style="width: 33%;"><div t-if="doc.partner_shipping_id != doc.partner_id">Shipping address:</div></th>
                    <th style="width: 33%;"><div t-if="doc.partner_invoice_id != doc.partner_id">Invoicing address:</div></th>
                    <th>Customer:</th>
                </thead>
                <tbody>
                    <td><div t-if="doc.partner_shipping_id != doc.partner_id" t-field="doc.partner_shipping_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": true, "phone_icons": true}'/></td>
                    <td><div t-if="doc.partner_invoice_id != doc.partner_id" t-field="doc.partner_invoice_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": true, "phone_icons": true}'/></td>
                    <td>
                        <div t-field="doc.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": true}'/>
                        <p t-if="doc.partner_id.vat"><t t-esc="doc.company_id.country_id.vat_label or 'Tax ID'"/>: <span t-field="doc.partner_id.vat"/></p>
                    </td>
                </tbody>
            </table>
            <br/>
        </xpath>

        <!-- GESTION DU CARTOUCHE -->
        <xpath expr="//div[@id='informations']" position="replace">
            <div class="row mt32 mb32" id="informations">
                <div class="col-auto mw-100 mb-2" style="font-size: 14px;">
                    <strong>Your reference:</strong>
                    <p class="m-0" t-field="doc.client_order_ref"/>
                </div>
                <!-- v17 : confirmation_date removed → use date_order for all states -->
                <div t-if="doc.date_order and doc.state not in ['draft','sent']" class="col-auto mw-100 mb-2" style="font-size: 14px;">
                    <strong>Date Ordered:</strong>
                    <p class="m-0" t-field="doc.date_order"/>
                </div>
                <div t-if="doc.date_order and doc.state in ['draft','sent']" class="col-auto mw-100 mb-2" style="font-size: 14px;">
                    <strong>Quotation Date:</strong>
                    <p class="m-0" t-field="doc.date_order"/>
                </div>
                <div name="payment_term" t-if="doc.payment_term_id" class="col-auto mw-100 mb-2" style="font-size: 14px;">
                    <strong>Payment Terms:</strong>
                    <p class="m-0" t-field="doc.payment_term_id"/>
                </div>
                <div t-if="doc.validity_date and doc.state in ['draft', 'sent']" class="col-auto mw-100 mb-2" style="font-size: 14px;">
                    <strong>Expiration Date:</strong>
                    <p class="m-0" t-field="doc.validity_date" style="font-size: 14px;"/>
                </div>
            </div>
            <table></table>
            <table style="width: 100%; border-spacing: 5px;">
                <tr style="border-top: 1px solid #dde1e6;">
                    <td style="font-size: 14px;"><b>Salesperson:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.user_id"/></td>
                    <td style="font-size: 14px;"><b>Responsible business:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.responsible_business_id"/></td>
                </tr>
                <tr>
                    <td style="font-size: 14px;"><b>Phone:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.user_id.phone"/></td>
                    <td style="font-size: 14px;"><b>Phone:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.phone_responsible_business"/></td>
                </tr>
                <tr style="border-bottom: 1px solid #dde1e6;">
                    <td style="font-size: 14px;"><b>Email:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.user_id.partner_id.email"/></td>
                    <td style="font-size: 14px;"><b>Email:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.mail_responsible_business"/></td>
                </tr>
            </table>
            <br/>
            <table style="width: 100%;">
                <tr>
                    <td style="font-size: 14px; width: 20%;"><b>Project:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.project_id"/></td>
                </tr>
                <tr>
                    <td style="font-size: 14px;"><b>Project reference:</b></td>
                    <td style="font-size: 14px;"><span t-field="doc.project_id.title_project"/></td>
                </tr>
            </table>
            <br/>
        </xpath>

        <!-- MODIFICATION ENTETE DE LA LISTE DES ARTICLES -->
        <!-- v17 : drop style attribute filter (may have changed) -->
        <xpath expr="//table[contains(@class,'o_main_table')]/thead" position="replace">
            <thead>
                <tr>
                    <!-- TODO: remove in master -->
                    <t t-set="colspan" t-value="5"/>
                    <th class="text-left" style="background-color: #dde1e6;">Description</th>
                    <th class="text-end" style="background-color: #dde1e6;">Quantity</th>
                    <th class="text-end" style="background-color: #dde1e6;">Unit Price</th>
                    <th t-if="display_discount" class="text-end" style="background-color: #dde1e6;" groups="sale.group_discount_per_so_line">
                        <span>Disc.(%)</span>
                        <!-- TODO: remove in master -->
                        <t t-set="colspan" t-value="colspan+1"/>
                    </th>
                    <th class="text-end" style="background-color: #dde1e6;">Taxes</th>
                    <th class="text-end" style="background-color: #dde1e6;">
                        <t groups="account.group_show_line_subtotals_tax_excluded">Amount</t>
                        <t groups="account.group_show_line_subtotals_tax_included">Total Price</t>
                    </th>
                </tr>
            </thead>
        </xpath>

        <!-- POUR AJOUTER LA SIGNATURE -->
        <xpath expr="//div[@name='total']" position="after">
            <div t-if="doc.state in ['draft','sent']">
                <br/>
                <div class="pull-right" style="width: 250px;">
                    <p><b>Good for agreement:</b><br/>
                    The :<br/>
                    Signature :</p>
                </div>
            </div>
        </xpath>

        <!-- POUR MODIFIER LE LIBELLE SOUS TOTAL HT DES SECTIONS -->
        <xpath expr="//tr[@class='is-subtotal text-end']/td/strong" position="replace">
            <strong class="mr16">Sous Total HT</strong>
        </xpath>

        <!-- POUR AJOUTER LA NOTE SUPPLEMENTAIRE -->
        <xpath expr="//span[@name='order_note']" position="after">
            <p t-field="doc.comment_not"/>
        </xpath>

        <!-- POUR AJOUTER LE DOSSIER TECHNIQUE -->
        <xpath expr="//div[hasclass('page')]" position="after">
            <span t-if="doc.print_technical_document == true">
                <p style="page-break-before:always;"><span t-out="doc.technical_document"/></p>
            </span>
        </xpath>

        <!-- POUR REDUIRE LA TAILLE DU TEXTE DES CONDITIONS -->
        <xpath expr="//p[@t-if='not is_html_empty(doc.payment_term_id.note)']" position="attributes">
            <attribute name="style">font-size: 12px;</attribute>
        </xpath>
    </template>
</odoo>

