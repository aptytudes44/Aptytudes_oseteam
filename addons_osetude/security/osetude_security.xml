<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Catégorie pour les groupes de contrôle qualité -->
        <record model="ir.module.category" id="module_category_quality_oseteam">
            <field name="name">Quality Control</field>
            <field name="visible">False</field>
        </record>

        <!-- Groupes personnalisés -->
        <record model="res.groups" id="group_create_purchase_in_sale">
            <field name="name">OSETEAM/Créer des demandes d'achats dans les ventes</field>
            <field name="comment">Permet de créer des demandes d'achats directement depuis les commandes de vente</field>
        </record>

        <record model="res.groups" id="group_recreate_folder_project">
            <field name="name">OSETEAM/Recréer des dossiers projet</field>
            <field name="comment">Permet de recréer des dossiers de projet</field>
        </record>

        <record model="res.groups" id="group_set_picking_to_draft">
            <field name="name">OSETEAM/Passer les bons de livraison au brouillon</field>
            <field name="comment">Permet de repasser les bons de livraison en statut brouillon</field>
        </record>

        <record model="res.groups" id="group_resource_planning_manager">
            <field name="name">OSETEAM/Manager Ressources Planning</field>
            <field name="comment">Gestion complète du planning des ressources</field>
        </record>

        <!-- Groupes Contrôles Qualité -->
        <record model="res.groups" id="group_quality_control_user">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="category_id" ref="module_category_quality_oseteam"/>
        </record>

        <record model="res.groups" id="group_quality_control_manager">
            <field name="name">Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_quality_control_user'))]"/>
            <field name="category_id" ref="module_category_quality_oseteam"/>
        </record>
    </data>
</odoo>
