    <record id="view_quality_control_quality_noncompliance_form" model="ir.ui.view">
        <field name="name">quality.control.quality.noncompliance.form</field>
        <field name="model">quality.control.quality.noncompliance</field>
        <field name="arch" type="xml">
            <form string="Quality controls" create="0">
                <sheet>
                    <h1><field name="name" modifiers="{'readonly': True}" force_save="1"/></h1>
                    <group>
                        <group string="Identification">
                            <field name="type"/>
                            <field name="imputation"/>
                            <field name="partner_id"
                                   modifiers="{'invisible': ['|',('imputation','=','internal'),('imputation','=',False)], 'required': [('imputation','in',('customer','supplier'))]}"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="project_id"/>
                            <field name="sale_id"
                                   modifiers="{'invisible': [('imputation','!=','customer')], 'required': [('imputation','=','customer')]}"
                                   domain="[('project_id','=',project_id)]"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="purchase_id"
                                   modifiers="{'invisible': [('imputation','!=','supplier')], 'required': [('imputation','=','supplier')]}"
                                   options="{'no_open': True, 'no_create': True}"/>
                        </group>
                        <group string="Responsible">
                            <field name="state"/>
                            <field name="user_id" modifiers="{'required': True}"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="date_of_issue" modifiers="{'required': True}"/>
                            <field name="close_date"/>
                            <field name="company_id"
                                   options="{'no_open': True, 'no_create': True}" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <group string="Description">
                            <field name="noncompliance_cause_id"
                                   options="{'no_open': True, 'no_create': True}"
                                   modifiers="{'required': True}"/>
                            <field name="severity_level" modifiers="{'required': True}"/>
                            <field name="noncompliant_note" modifiers="{'required': True}"/>
                            <field name="immediate_correction_note"/>
                        </group>
                        <group string="Part reserved for quality control">
                            <field name="root_causes"/>
                            <field name="description_correction"/>
                            <field name="measure_effectiveness_correction" modifiers="{'invisible': True}"/>
                        </group>
                        <group string="Cost and balance">
                            <field name="study" widget="monetary"/>
                            <field name="production" widget="monetary"/>
                            <field name="comment"/>
                        </group>
                        <group string="Characterization of the problem and search for root causes">
                            <field name="root_causes_filename" invisible="1"/>
                            <field name="root_causes_binary" filename="root_causes_filename"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_view_quality_control_all" model="ir.actions.act_window">
        <field name="name">Quality controls</field>
        <field name="res_model">quality.control.quality.noncompliance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Quality control Noncompliance
            </p>
        </field>
    </record>

    <menuitem name="Other quality controls" id="menu_other_quality_control" parent="addons_osetude.menu_quality_control_menu" sequence="2"/>
    <menuitem name="Complaints et NC" id="menu_quality_control_all" action="action_view_quality_control_all" parent="addons_osetude.menu_other_quality_control" sequence="1"/>

    <record id="view_quality_control_quality_parameters_tree" model="ir.ui.view">
        <field name="name">quality.control.parameters.list</field>
        <field name="model">quality.control.parameters</field>
        <field name="arch" type="xml">
            <list string="Scale Files" create="0">
                <field name="selection_binary_model_filename"/>
                <field name="quotation_binary_model_filename"/>
            </list>
        </field>
    </record>

    <record id="view_quality_control_parameters_form" model="ir.ui.view">
        <field name="name">quality.control.parameters.form</field>
        <field name="model">quality.control.parameters</field>
        <field name="arch" type="xml">
            <form string="Quality controls parameters" create="false">
                <sheet>
                    <group string="Scale Files">
                        <field name="selection_binary_model_filename" invisible="1"/>
                        <field name="selection_binary_model" filename="selection_binary_model_filename"/>
                        <field name="quotation_binary_model_filename" invisible="1"/>
                        <field name="quotation_binary_model" filename="quotation_binary_model_filename"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_view_quality_control_file_parameters" model="ir.actions.act_window">
        <field name="name">Quality control parameters</field>
        <field name="res_model">quality.control.parameters</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="view_id" ref="view_quality_control_quality_parameters_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Quality control parameters
            </p>
        </field>
    </record>

    <menuitem id="quality_controls_parameters_menu"
        name="Configuration"
        parent="quality_controls_menu_root"
        sequence="15"/>

    <menuitem name="Scale file parameters"
        id="scale_file_parameters_menu"
        parent="quality_controls_parameters_menu"
        sequence="20"
        action="action_view_quality_control_file_parameters"
        groups="group_quality_control_user,group_quality_control_manager"/>
</odoo>

