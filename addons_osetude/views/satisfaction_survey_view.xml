<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_satisfaction_survey_parameters_tree" model="ir.ui.view">
        <field name="name">Satisfaction survey parameters tree</field>
        <field name="model">satisfaction.survey.parameters</field>
        <field name="arch" type="xml">
            <list string="Satisfaction survey parameters">
                <field name="report_id"/>
                <field name="report_name"/>
                <field name="satisfaction_survey_binary_model"/>
                <field name="satisfaction_survey_binary_model_filename"/>
                <field name="report_print_sequence"/>
            </list>
        </field>
    </record>

    <record id="view_satisfaction_survey_form" model="ir.ui.view">
        <field name="name">Satisfaction survey parameters form</field>
        <field name="model">satisfaction.survey.parameters</field>
        <field name="arch" type="xml">
            <form string="Satisfaction survey parameters">
                <sheet>
                    <group>
                        <group>
                            <field name="report_id" modifiers="{'required': True}" options="{'no_open': True}"/>
                            <field name="report_name"/>
                        </group>
                        <group>
                            <field name="satisfaction_survey_binary_model_filename" invisible="1"/>
                            <field name="satisfaction_survey_binary_model" modifiers="{'required': True}" filename="satisfaction_survey_binary_model_filename"/>
                            <field name="report_print_sequence"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_view_satisfaction_survey_parameters" model="ir.actions.act_window">
        <field name="name">satisfaction.survey.parameters</field>
        <field name="res_model">satisfaction.survey.parameters</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="view_id" ref="view_satisfaction_survey_parameters_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Satisfaction survey parameters
            </p>
        </field>
    </record>

    <menuitem name="satisfaction parameters"
        id="satisfaction_survey_parameters_menu"
        parent="addons_osetude.quality_controls_parameters_menu"
        sequence="30"
        action="action_view_satisfaction_survey_parameters"
        groups="group_quality_control_user,group_quality_control_manager"/>
</odoo>

