    <record id="view_picking_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="set_to_draft"
                    string="Set to draft"
                    type="object"
                    class="oe_highlight"
                    invisible="state=='done'" 
                    groups="addons_osetude.group_osetude_set_picking_draft"
                    confirm="Are you sure you want to draft the document?"/>
            </xpath>
            <xpath expr="//h1" position="after">
                <div class="alert alert-warning" role="alert" invisible="print_deliveryslip_ok or not project_id">
                    deliveryslip non printable (check the project checklist)
                </div>
            </xpath>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="project_id"/>
            </xpath>
            
            <!-- ############################# LE CHAMP NAME N'EST PLUS DANS LA VUE 
            <xpath expr="//field[@name='move_ids']/list/field[@name='name']" position="replace"/>
            <xpath expr="//field[@name='move_ids']/list/field[@name='product_id']" position="after">
                <field name="name" readonly="1"/>
            </xpath>
            -->
            
            <xpath expr="//notebook" position="before">
                <group>
                    <field name="delivery_note"/>
                    <field name="print_deliveryslip_ok" invisible="1"/>
                    <field name="print_satisfaction_ok" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>
   
</odoo>

