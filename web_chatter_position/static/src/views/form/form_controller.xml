<templates xml:space="preserve">

    <t
        t-name="web_chatter_position.FormView"
        t-inherit="web.FormView"
        t-inherit-mode="extension"
    >
        <xpath
            expr="//t[@t-set-slot='control-panel-create-button'][last()]"
            position="after"
        >
            <t t-set-slot="control-panel-always-buttons">
                <button
                    t-if="isChatterToggleVisible"
                    type="button"
                    class="btn btn-secondary o_chatter_position_button"
                    t-on-click="onClickChangePosition"
                    title="Toggle chatter position"
                >
                    <i class="fa fa-exchange" />
                </button>
            </t>
        </xpath>
    </t>

</templates>
